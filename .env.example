# ─── Required ───────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ─── Modal GPU Services ────────────────────────────────────────
# Get URLs after running: modal deploy stt_server.py && modal deploy tts_server.py
WHISPER_STT_URL=https://your-org--whisper-stt-server.modal.run
FISH_TTS_URL=https://your-org--fish-tts-server.modal.run

# ─── OpenClaw Bridge (optional) ────────────────────────────────
# If set, bot sends transcribed text to Aris instead of using LLM directly
# Leave empty to use OpenRouter LLM directly (simpler, but no Aris tools/memory)
OPENCLAW_GATEWAY_URL=

# ─── Bot Security ──────────────────────────────────────────────
# Secret for /speak endpoint (Aris pushes voice to connected browsers)
BOT_SECRET=change-me-to-something-random

# ─── Optional ───────────────────────────────────────────────────
# Bot HTTP port (default: 7860)
BOT_PORT=7860

# LLM model for direct mode (when no OpenClaw bridge)
LLM_MODEL=xiaomi/mimo-v2-pro

# Voice reference ID for Fish Speech (optional, for voice cloning)
FISH_VOICE_ID=

# Whisper model (default: large-v3)
WHISPER_MODEL=large-v3

# ─── Daily.co (for production WebRTC instead of SmallWebRTC) ───
# Only needed if using Daily transport
DAILY_API_KEY=
DAILY_API_URL=https://api.daily.co
