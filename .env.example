# ─── Required ───────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ─── Modal GPU Server ───────────────────────────────────────────
# Single Modal server runs both Whisper STT + Fish Speech TTS
# Deploy: modal deploy server.py
VOICE_SERVER_URL=https://your-org--aris-voice-server.modal.run

# ─── OpenClaw Bridge ────────────────────────────────────────────
# Routes voice to your Aris instance (same LAN as Synology)
OPENCLAW_GATEWAY_URL=ws://192.168.178.134:18789
OPENCLAW_GATEWAY_TOKEN=your-token-here

# ─── Bot Security ──────────────────────────────────────────────
# Secret for /speak endpoint (Aris pushes voice to connected browsers)
BOT_SECRET=change-me-to-something-random

# ─── Optional ───────────────────────────────────────────────────
# Bot HTTP port (default: 7860)
BOT_PORT=7860

# LLM model for direct mode (when no OpenClaw bridge)
LLM_MODEL=xiaomi/mimo-v2-pro

# Voice reference ID for Fish Speech (optional, for voice cloning)
FISH_VOICE_ID=

# Whisper model (default: large-v3)
WHISPER_MODEL=large-v3

# ─── Daily.co (for production WebRTC instead of SmallWebRTC) ───
# Only needed if using Daily transport
DAILY_API_KEY=
DAILY_API_URL=https://api.daily.co
